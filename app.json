{
  "expo": {
    "name": "JSON.fit",
    "slug": "json",
    "version": "1.0.20",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "scheme": "json-app",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.RyanNovinc.JSON",
      "buildNumber": "94",
      "associatedDomains": ["applinks:json.fit"],
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "CFBundleDisplayName": "JSON.fit",
        "CFBundleName": "JSON.fit",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.RyanNovinc.JSON",
      "versionCode": 94,
      "edgeToEdgeEnabled": true,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "permissions": [],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "json.fit",
              "pathPrefix": "/p/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "836fbcc1-7997-4d00-b9eb-5d259570a9a7"
      }
    },
    "owner": "ryan_novinc",
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-live-activity"
    ]
  }
}
