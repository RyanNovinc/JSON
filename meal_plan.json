        {
          "id": "meal_20260313_breakfast",
          "name": "Weet-Bix Protein Bowl with Peanut Butter",
          "type": "breakfast",
          "time": "7:00 AM",
          "calories": 870,
          "macros": { "protein": 70, "carbs": 93, "fat": 23, "fiber": 7 },
          "ingredients": [
            { "item": "Weet-Bix biscuits", "amount": "4", "unit": "biscuits", "notes": "60g total" },
            { "item": "Coles Perform Protein Powder", "amount": "60", "unit": "g", "notes": "2 scoops, chocolate or vanilla" },
            { "item": "Full-cream milk", "amount": "300", "unit": "ml", "notes": "" },
            { "item": "Natural peanut butter", "amount": "20", "unit": "g", "notes": "1 tbsp — Mayver's or Coles brand" },
            { "item": "Banana", "amount": "1", "unit": "medium", "notes": "~120g, eaten on the side" }
          ],
          "instructions": [
            "Place 4 Weet-Bix in a bowl.",
            "Add 2 scoops protein powder on top.",
            "Add 1 tbsp peanut butter.",
            "Pour 300ml milk over everything.",
            "Eat the banana on the side."
          ],
          "tags": ["high_protein", "assembly_only", "no_cook"],
          "isOriginal": true,
          "addedAt": "2026-03-12T14:30:00.000Z"
        },
        {
          "id": "meal_20260313_lunch",
          "name": "Tuna & Rice Crackers Plate with Greek Yoghurt",
          "type": "lunch",
          "time": "12:00 PM",
          "calories": 830,
          "macros": { "protein": 70, "carbs": 54, "fat": 37, "fiber": 7 },
          "ingredients": [
            { "item": "Coles Own Brand Tuna in Olive Oil 95g", "amount": "2", "unit": "cans", "notes": "Drain lightly" },
            { "item": "Sakata Rice Crackers", "amount": "25", "unit": "g", "notes": "Roughly half a 100g bag" },
            { "item": "Coles Hummus", "amount": "100", "unit": "g", "notes": "Half a 200g tub" },
            { "item": "Baby spinach leaves", "amount": "60", "unit": "g", "notes": "Pre-washed bag" },
            { "item": "Full-fat Greek yoghurt", "amount": "200", "unit": "g", "notes": "Chobani or Coles brand" }
          ],
          "instructions": [
            "Open both tuna tins, drain lightly.",
            "Place spinach on a plate or in a bowl.",
            "Tip tuna over spinach.",
            "Serve crackers and hummus on the side.",
            "Eat yoghurt as a separate side."
          ],
          "tags": ["high_protein", "assembly_only", "no_cook"],
          "isOriginal": true,
          "addedAt": "2026-03-12T14:30:00.000Z"
        },
