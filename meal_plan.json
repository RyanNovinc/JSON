        },
        {
          "id": "meal_20260313_dinner",
          "name": "Rotisserie Chicken Rice Bowl",
          "type": "dinner",
          "time": "5:30 PM",
          "calories": 910,
          "macros": { "protein": 77, "carbs": 113, "fat": 16, "fiber": 5 },
          "ingredients": [
            { "item": "Pre-pulled rotisserie chicken", "amount": "200", "unit": "g", "notes": "From Coles Hot Roast Chicken, skin removed" },
            { "item": "SunRice Brown Rice Microwave Pouch", "amount": "1", "unit": "pouch", "notes": "250g pouch" },
            { "item": "Frozen corn", "amount": "80", "unit": "g", "notes": "Birds Eye" },
            { "item": "Full-fat Greek yoghurt", "amount": "100", "unit": "g", "notes": "Served as a side" },
            { "item": "BBQ or sweet chilli sauce", "amount": "30", "unit": "g", "notes": "~2 tbsp" }
          ],
          "instructions": [
            "Microwave rice pouch for 90 seconds per packet instructions.",
            "Microwave frozen corn in a small bowl with 1 tbsp water for 2 minutes.",
            "Pull chicken from container with a fork into the bowl — no knife needed.",
            "Combine rice, corn, and chicken in a large bowl. Drizzle sauce over.",
            "Eat yoghurt on the side."
          ],
          "tags": ["high_protein", "microwave_only", "meal_prep"],
          "isOriginal": true,
          "addedAt": "2026-03-12T14:30:00.000Z"
        }
      ]
    },
