  "dailyMeals": {
    "2025-03-08": {
      "date": "2025-03-08",
      "dayName": "Sunday",
      "meals": [
        {
          "id": "meal_20250308_breakfast",
          "name": "Protein Oats & Yogurt Bowl",
          "type": "breakfast",
          "time": "7:00 AM",
          "calories": 787,
          "macros": { "protein": 42, "carbs": 105, "fat": 22, "fiber": 18 },
          "ingredients": [
            { "item": "Uncle Tobys Quick Oats", "amount": "80", "unit": "g", "notes": "Pre-portioned into daily zip-lock bag Sunday" },
            { "item": "Full-fat milk", "amount": "200", "unit": "ml", "notes": "Used instead of water for extra calories and fat" },
            { "item": "Coles Perform High Protein Greek Yoghurt", "amount": "200", "unit": "g", "notes": "Stir in after microwaving" },
            { "item": "Psyllium husk powder", "amount": "10", "unit": "g", "notes": "Stir into oats before microwaving — unflavoured, adds fiber" },
            { "item": "Banana", "amount": "1", "unit": "medium (~120g)", "notes": "Place on top" },
            { "item": "Peanut butter (smooth)", "amount": "20", "unit": "g", "notes": "1 tablespoon on top" }
          ],
          "instructions": [
            "Tip pre-portioned 80g oats bag into a microwave-safe bowl",
            "Add 200ml full-fat milk",
            "Stir in 10g psyllium husk powder",
            "Microwave on HIGH for 2 minutes",
            "Stir well, then spoon 200g Greek yoghurt on top and stir through",
            "Add banana on top and add peanut butter — eat immediately"
          ],
          "tags": ["high_protein", "high_fiber", "assembly_only", "microwave", "routine"],
          "isOriginal": true,
          "addedAt": "2025-03-08T07:00:00.000Z"
        },
        {
          "id": "meal_20250308_lunch",
          "name": "Chicken Rice Bowl with Nuts",
          "type": "lunch",
          "time": "11:00 AM",
          "calories": 903,
          "macros": { "protein": 63, "carbs": 82, "fat": 31, "fiber": 5 },
          "ingredients": [
            { "item": "Shredded rotisserie chicken", "amount": "200", "unit": "g", "notes": "Pre-shredded from Sunday assembly — take from container" },
            { "item": "SunRice Microwave Long Grain White Rice Pouch", "amount": "1", "unit": "pouch (250g)", "notes": "Microwave 90 seconds as directed on pack" },
            { "item": "Pre-washed baby spinach", "amount": "100", "unit": "g", "notes": "Grab directly from bag — no prep needed" },
            { "item": "Raw mixed nuts", "amount": "30", "unit": "g", "notes": "Almonds and cashews — grab a handful" },
            { "item": "Kikkoman soy sauce", "amount": "40", "unit": "ml", "notes": "2 tablespoons — drizzle over bowl" }
          ],
          "instructions": [
            "Microwave SunRice pouch for 90 seconds as directed on pack",
            "Tip rice into a bowl",
            "Top with 200g shredded chicken from container",
            "Grab 100g spinach from bag and place on top",
            "Scatter 30g mixed nuts over",
            "Drizzle 40ml soy sauce over everything, stir loosely and eat"
          ],
          "tags": ["high_protein", "meal_prep", "assembly_only", "microwave", "routine"],
          "isOriginal": true,
          "addedAt": "2025-03-08T11:00:00.000Z"
        },
        {
          "id": "meal_20250308_snack",
          "name": "Cottage Cheese, Fruit & Protein Bar",
          "type": "snack",
          "time": "2:30 PM",
          "calories": 473,
          "macros": { "protein": 73, "carbs": 32, "fat": 9, "fiber": 5 },
          "ingredients": [
            { "item": "Bulla Low Fat Cottage Cheese", "amount": "200", "unit": "g", "notes": "From pre-portioned container — grab from fridge" },
            { "item": "Strawberries", "amount": "150", "unit": "g", "notes": "Rinse under tap, snap tops off by hand — no knife needed" },
            { "item": "Musashi P45 Protein Bar", "amount": "1", "unit": "bar (90g)", "notes": "Eat alongside. Substitute Coles brand protein bar if unavailable." }
          ],
          "instructions": [
            "Take pre-portioned cottage cheese container from fridge",
            "Rinse 150g strawberries under tap and snap tops off by hand",
            "Place strawberries on top of cottage cheese",
            "Eat protein bar alongside"
          ],
          "tags": ["high_protein", "no_cook", "assembly_only", "routine"],
          "isOriginal": true,
          "addedAt": "2025-03-08T14:30:00.000Z"
        },
        {
          "id": "meal_20250308_dinner",
          "name": "Tuna Crackers & Cottage Cheese Plate",
          "type": "dinner",
          "time": "5:30 PM",
          "calories": 694,
          "macros": { "protein": 75, "carbs": 72, "fat": 8, "fiber": 8 },
          "ingredients": [
            { "item": "Coles Tuna Chunks in Springwater", "amount": "2", "unit": "cans (95g each)", "notes": "Drain water by pressing lid down firmly" },
            { "item": "Bulla Low Fat Cottage Cheese", "amount": "150", "unit": "g", "notes": "Scoop into small bowl on the side" },
            { "item": "Vita-Weat Original Crackers", "amount": "50", "unit": "g", "notes": "Approximately 14 crackers" },
            { "item": "Lebanese cucumber", "amount": "1", "unit": "whole (~150g)", "notes": "Eat whole — snap ends off by hand, no knife needed" },
            { "item": "Banana", "amount": "1", "unit": "medium (~120g)", "notes": "Eat as dessert after main plate" }
          ],
          "instructions": [
            "Open both tuna cans and drain water by pressing lid firmly against tuna",
            "Place tuna on plate next to crackers",
            "Scoop 150g cottage cheese into a small bowl",
            "Place cucumber on the side — snap ends off by hand",
            "Eat banana as dessert"
          ],
          "tags": ["high_protein", "no_cook", "assembly_only", "omega3", "routine"],
          "isOriginal": true,
          "addedAt": "2025-03-08T17:30:00.000Z"
        }
      ]
    },
